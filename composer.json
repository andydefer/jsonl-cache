{
    "name": "andydefer/jsonl-cache",
    "description": "PSR-16 compatible JSONL-based cache system with key-based path strategy",
    "license": "MIT",
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0|^13.0|^14.0|^15.0",
        "andydefer/laravel-jsonl": "^0.8.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "laravel/pint": "^1.26",
        "orchestra/testbench": "^10.8",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "AndyDefer\\JsonlCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\JsonlCache\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AndyDefer\\JsonlCache\\JsonlCacheServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-unit": "phpunit --testsuite=unit",
        "test-integration": "phpunit --testsuite=integration",
        "pint": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
